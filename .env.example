# Copy to .env for local development (never commit real secrets).

# DigiKey API credentials (required to actually resolve parts; the app boots without
# them, but jobs will error until they're set).
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Session signing key. Use a long random value in production.
SECRET_KEY=dev-insecure-change-me

# Storage. SQLite for dev; swap for a Postgres URL for durable writes.
DATABASE_URL=sqlite:///./capinator.db

# Seed catalog / admin
SEED_FILE=seed/component_lists.yaml
SEED_ON_STARTUP=true
SEED_OWNER_EMAIL=curator@capinator.local
# Comma-separated admin emails (defaults to SEED_OWNER_EMAIL if empty)
ADMIN_EMAILS=

# Limits
GUEST_JOB_LIMIT=2
MAX_SPEC_ROWS=100
