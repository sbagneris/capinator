# Copy to .env for local development (never commit real secrets).

# DigiKey API credentials (required to actually resolve parts; the app boots without
# them, but jobs will error until they're set).
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Session signing key — REQUIRED. Generate one with `openssl rand -hex 32`, and
# KEEP IT STABLE: it signs sessions AND keys the API-token HMAC, so changing it logs
# everyone out and invalidates every issued API key. (Compose refuses to start if unset.)
SECRET_KEY=

# Storage. SQLite for dev; Postgres for durable writes. Under Docker Compose this is
# auto-derived from POSTGRES_* below (compose overrides it), so this value only applies
# when running uvicorn directly without compose.
DATABASE_URL=sqlite:///./capinator.db

# Seed catalog / admin
SEED_FILE=seed/component_lists.yaml
SEED_ON_STARTUP=true
SEED_OWNER_EMAIL=curator@capinator.local
# Comma-separated admin emails (defaults to SEED_OWNER_EMAIL if empty)
ADMIN_EMAILS=

# Limits
GUEST_JOB_LIMIT=2
MAX_SPEC_ROWS=100

# --- Docker Compose deployment (VPS) -----------------------------------------------
# Public hostname for Caddy's automatic HTTPS: a real domain whose DNS A record points
# at this server (Caddy fetches a Let's Encrypt cert), or a local name like `localhost`
# for self-signed TLS before DNS is ready.
DOMAIN=localhost

# Postgres credentials. Compose derives the app's DATABASE_URL from these
# (postgresql+psycopg://USER:PASSWORD@db:5432/DB) and overrides the sqlite value above.
# POSTGRES_PASSWORD is REQUIRED — generate one (e.g. `openssl rand -hex 24`); compose
# refuses to start if it's empty. NOTE: a literal `$` in any value here must be escaped
# as `$$`, or Compose will interpolate it as a variable and silently mangle the value.
POSTGRES_USER=capinator
POSTGRES_PASSWORD=
POSTGRES_DB=capinator

# Mark the session cookie Secure (compose forces this on behind Caddy's TLS; set true for
# any other HTTPS deployment, leave false for plain-http local dev).
COOKIE_SECURE=false
